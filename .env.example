# Database
DATABASE_URL="file:./dev.db"

# DeepSeek API (for AI generate and translate features)
# Get your API key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Internal daily materials cron token
DAILY_JOB_SECRET=

# TTS Provider: "browser" or "volcengine"
# browser — use browser built-in speechSynthesis, no server calls
# volcengine — use Volcengine Doubao TTS with MP3 file caching
NEXT_PUBLIC_TTS_PROVIDER=volcengine

# Enable remote TTS API (must be "true" for volcengine provider)
ENABLE_REMOTE_TTS=true

# Volcengine Doubao TTS credentials
# Get these from https://console.volcengine.com/
VOLCENGINE_TTS_APP_ID=
VOLCENGINE_TTS_ACCESS_TOKEN=
VOLCENGINE_TTS_CLUSTER=volcano_tts
VOLCENGINE_TTS_VOICE_TYPE=

# Volcengine TTS audio parameters (optional)
# VOLCENGINE_TTS_RATE=24000
# VOLCENGINE_TTS_ENCODING=mp3
# VOLCENGINE_TTS_SPEED_RATIO=1.0
# VOLCENGINE_TTS_PITCH_RATIO=1.0
# VOLCENGINE_TTS_VOLUME_RATIO=1.0
